# docker compose 的必填 secret。复制为 .env（已 .gitignore）并填入随机值：
#
#   cp .env.example .env
#   sed -i "s/^JWT_SECRET=.*/JWT_SECRET=$(openssl rand -hex 32)/" .env
#   sed -i "s|^STUDIO_CONFIG_ENC_KEY=.*|STUDIO_CONFIG_ENC_KEY=$(openssl rand -base64 32)|" .env
#
# JWT_SECRET: 会话签名密钥。泄露 = 任意伪造登录态。
JWT_SECRET=

# STUDIO_CONFIG_ENC_KEY: BYOK 模型密钥 / 存储 secret 的 AES-256-GCM 加密钥匙（base64 32B）。
# 不设则无法保存任何带密钥的配置；轮换无在线路径（见 README「密钥轮换」）。
STUDIO_CONFIG_ENC_KEY=

# 可选：LLM provider key（compose 里已从宿主 env 透传，也可写在这里）。
# API_KEY=
# OPENAI_API_KEY=
# MINIMAX_API_KEY=
